[MASTER]
extension-pkg-allow-list=cv2
init-hook=import sys; sys.path.insert(0, 'src')
py-version=3.10

[MESSAGES CONTROL]
disable=
    fixme,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    line-too-long,
    trailing-whitespace,
    missing-final-newline,
    wrong-import-position,
    wrong-import-order,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-instance-attributes,
    too-few-public-methods,
    invalid-name,
    broad-exception-caught,
    broad-exception-raised,
    duplicate-code,
    protected-access,
    unused-import,
    unused-variable

[TYPECHECK]
generated-members=cv2.*
ignored-modules=
    cv2,
    numpy,
    pandas,
    onnxruntime,
    sklearn,
    ultralytics,
    aiohttp,
    dotenv,
    paho.mqtt.client,
    schedule,
    loguru,
    pytest,
    joblib
