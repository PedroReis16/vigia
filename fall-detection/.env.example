DATA_PATH=data/

# Duração de cada janela poses_XXXXXX: CSV em DATA_PATH/coordinates/, último frame em DATA_PATH/frames/ (mesmo stem).
POSE_CSV_WINDOW_SECONDS=3

# Índice da câmera (0 = webcam do notebook) ou URL (http/rtsp) de stream no iPhone.
# Continuity Camera / EpocCam no Mac: tente 1 ou 2 se o 0 for o notebook.
VIDEO_CAPTURE_SOURCE=1

CAPTURES_PER_SECOND=10

SHOW_VIDEO=True

YOLO_POSE_MODEL=yolo26s-pose

# Dispositivo de execução do modelo YOLO
YOLO_MODEL_DEVICE=cpu

FIWARE_PATH=https://www.vigia-deteccoes.duckdns.org
FIWARE_SERVICE=vigia
FIWARE_MQTT_HOST=vigia-deteccoes.duckdns.org
FIWARE_MQTT_PORT=1883
# FIWARE_MQTT_USERNAME=
# FIWARE_MQTT_PASSWORD=
FIWARE_MQTT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=10

STREAM_INGEST_URL=rtmp://localhost:1935/live/