# Copie para `.env` no mesmo diretório deste arquivo e ajuste.
# Compose carrega `.env` automaticamente quando o ficheiro de compose está em `deploy/`.

# ─── DNS público (rotas Traefik / TLS) ───────────────────────────────────────
# Ambos devem resolver para o IP da VM. Se só existir o apex, repita o mesmo FQDN nos dois.
VIGIA_PUBLIC_HOST=vigia-deteccoes.duckdns.org
VIGIA_PUBLIC_HOST_WWW=www.vigia-deteccoes.duckdns.org

# ─── Imagens Docker ─────────────────────────────────────────────────────────
VIGIA_API_IMAGE=pedroreis16/vigia:latest
VIGIA_FRONTEND_IMAGE=pedroreis16/vigia-frontend:latest
VIGIA_STREAM_IMAGE=pedroreis16/vigia-stream:latest

# ─── vigia-stream: porta TCP publicada no host (câmera / fall-detection → VM) ─
# Dentro do container continua 8090; só a porta do host muda aqui.
# Se usar só POST https://…/ingest (Traefik), pode remover `ports:` do serviço vigia-stream.
VIGIA_STREAM_HOST_PORT=8090

# Token opcional; se definido, fall-detection deve enviar header X-Vigia-Ingest-Token igual.
VIGIA_INGEST_TOKEN=
